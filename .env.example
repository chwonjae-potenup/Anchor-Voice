# ================================
# Anchor-Voice 환경 변수 설정
# ================================
# 사용법: 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# ── LLM API Keys ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here       # Google AI Studio에서 발급
OPENAI_API_KEY=your_openai_api_key_here       # GPT fallback용 (선택)

# ── 위험도 판별 임계값 ────────────────────────────────
RISK_THRESHOLD_HIGH=70     # 이 값 이상 → 고위험 (Anchor-Voice 진입)
RISK_THRESHOLD_LOW=30      # 이 값 미만 → 저위험 (DeepFace 인증)

# ── 서버 설정 ─────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PUBLIC_HOST=localhost
BACKEND_SCHEME=http
BACKEND_PORT=8000
FRONTEND_HOST=localhost
FRONTEND_PORT=8501
FRONTEND_BASE_URL=http://localhost:8501   # optional override
API_BASE_URL=http://localhost:8000         # optional override

# ── Whisper 모델 크기 ──────────────────────────────────
# 선택: tiny / base / small / medium / large
WHISPER_MODEL_SIZE=base

# Whisper runtime tuning
WHISPER_DEVICE=auto            # auto / cuda / cpu
WHISPER_COMPUTE_TYPE=auto      # auto / float16 / int8 / int8_float16
WHISPER_BEAM_SIZE=1            # faster with lower beam
WHISPER_VAD_FILTER=true

# DeepFace runtime tuning
DEEPFACE_MODEL_NAME=ArcFace
DEEPFACE_MODEL_FALLBACK=VGG-Face
DEEPFACE_DETECTOR_BACKEND=opencv
# Optional multi-backend fallback (left→right order)
# Example: opencv,retinaface,mtcnn
DEEPFACE_DETECTOR_BACKENDS=opencv
DEEPFACE_DISTANCE_METRIC=cosine
DEEPFACE_REQUIRE_SECONDARY_METRIC=true
DEEPFACE_STRICT_MULTIPLIER=0.82
# Optional absolute cap (stricter than model threshold when needed)
# DEEPFACE_HARD_MAX_DISTANCE=0.45
# true: anti-spoof false-negative(안경 반사 등) 시 검출 성공하면 검증 단계로 진행
DEEPFACE_LIVENESS_SOFT_BYPASS=true

# Face sequence performance
FACE_SEQUENCE_MAX_FRAMES=18
FACE_FRAME_MAX_SIDE=720

# Warmup at backend startup (reduce first-request delay)
PRELOAD_WHISPER=true
PRELOAD_DEEPFACE=true
